<div class="flex flex-col gap-5 items-center px-16 bg-blue-200 py-16">
  <h2 class="text-5xl text-white text-center">Welcome to <br> <br> <span class="text-red-600 font-bold"> Amias Yaska Learning Platform </span></h2>

  <% if !user_signed_in? %>
    <div class="mt-5" >
      <%= link_to 'Sign in', new_user_session_path, class:"px-3 py-2 rounded-full bg-blue-500 text-white hover:bg-blue-300" %>
    </div>  

    <div class="mt-5">
      <%= link_to 'Sign up', new_user_registration_path, class:"px-3 py-2 rounded-full bg-green-500 text-white hover:bg-green-300" %>
    </div>
    
  <% end %>

</div>