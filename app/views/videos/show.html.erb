<div class="p-8 max-w-md mx-auto">
  
  <% if @video.thumbnail.attached? %>
    <%= image_tag @video.thumbnail, class:"w-full" %>
  <% end %>
  
  <h3 class="mt-2"><%= @video.title %></h3>

  <p class="mt-5"><%= @video.author %> </p>

  <p class="mt-5"><%= @video.description %> </p>

  <% if @video.enrollments.where(video: @video).exists? %>
    <p class="mt-2 text-xl ">Already enrolled</p>
  <% else %>
    <%= button_to 'Enroll Now' video_enrollment_path(@video), class:"py-2 px-2 rounded-lg bg-blue-500 text-white" %>
  <% end %>

</div>