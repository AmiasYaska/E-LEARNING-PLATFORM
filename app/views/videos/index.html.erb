<div class="flex items-center text-center">
  <%= form_with url: videos_path, method: :get, class:"flex gap-2" do %>
    <%= text_field_tag :search, 
      params[:search], placeholder: "Search for anything", 
      class:"border border-gray-400 rounded text-center" 
    %>
    
    <%= submit_tag "Search", class:"rounded-xl py-2 px-3 bg-blue-500 text-white hover:bg-blue-300" %>
  <% end %>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 p-8 gap-8">

  <% @videos.each do |video|%>
    <%= link_to video_path(video) do %>
      
      <% if video.thumbnail.attached? %>
        <%= image_tag video.thumbnail, class:"w-full h-48 rounded" %>
      <% end %>

      <h3 class="mt-2"><%= video.title %> </h3>

      <p class=""><%= video.author %> </p>
    <% end %>
      
  <% end %>
  
</div>