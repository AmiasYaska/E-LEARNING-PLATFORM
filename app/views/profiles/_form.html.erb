<div>
    <%= form_with model: user, url:profile_path do |form|%>

        <div class="mt-5">
            <%= form.text_field :first_name, class:"rounded border" %>
        </div>

        <div class="mt-5">
            <%= form.text_field :last_name, class:"rounded border " %>
        </div>

        <div class="mt-5">
            <%= form.email_field :email, class:"rounded border " %>
        </div>

        <div class="mt-5">
            <%= form.text_area :headline, class:"rounded border" %>
        </div>

        <div class="mt-5">
            <%= form.text_field :website, class:"rounded border" %>
        </div>

        <div class="mt-5">
            <%= form.button "Save", class:"py-2 px-3 bg-blue-400 text-white" %>
        </div>

    <% end %>
</div>