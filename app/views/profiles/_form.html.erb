<div>
    <%= form_with(model: user) do |form|%>

        <div class="mt-5">
            <%= form.text_field :first_name, class:"rounded border bg-gray-400" %>
        </div>

        <div class="mt-5">
            <%= form.text_field :last_name, class:"rounded border bg-gray-400" %>
        </div>

        <div class="mt-5">
            <%= form.email_field :email, class:"rounded border bg-gray-400" %>
        </div>

        <div class="mt-5">
            <%= form.text_area :headline, class:"rounded border bg-gray-400" %>
        </div>

        <div class="mt-5">
            <%= form.text_field :website, class:"rounded border bg-gray-400" %>
        </div>

        <div class="mt-5">
            <%= form.button "Save", class:"py-2 px-3 bg-blue-400 text-white" %>
        </div>

    <% end %>
</div>
