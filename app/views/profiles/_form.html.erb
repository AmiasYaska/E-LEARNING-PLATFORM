<div class="w-[600px] mx-auto">
    <%= form_with model: user, url:profile_path do |form|%>
        <div class="mt-5">
            <%= form.text_field :first_name, class:"w-full rounded border p-3 border-gray-400", placeholder: "First Name" %>
        </div>

        <div class="mt-5">
            <%= form.text_field :last_name, class:"w-full rounded border p-3 border-gray-400", placeholder: "Last Name" %>
        </div>

        <div class="mt-5">
            <%= form.email_field :email, class:"w-full rounded border p-3 border-gray-400", placeholder: "Email Address" %>
        </div>

        <div class="mt-5">
            <%= form.text_area :headline, class:"w-full resize-none rounded border p-3  border-gray-400", placeholder: "Headline" %>
        </div>

        <div>
            <%= form.select :language, options_for_select(@user.class::SUPPORTED_LANGUAGES, @user.language), {}, class:"border rounded w-full p-3" %>        
        </div>

        <div class="mt-5">
            <%= form.text_field :website, class:"w-full rounded border p-3 border-gray-400", placeholder: "Website" %>
        </div>

        <div class="mt-5">
            <%= form.button "Save", class:"py-2 px-3 bg-blue-400 text-white" %>
        </div>

    <% end %>
</div>